# DATABASE
DATABASE_URL="postgresql://postgres:postgres@db:5432/projecttt?schema=public"

# AUTH
JWT_ACCESS_SECRET="change-me-access-secret-32+chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-32+chars"
JWT_ACCESS_TTL_SECONDS="900"
JWT_REFRESH_TTL_SECONDS="1209600" # 14 days

# APP
NEXT_PUBLIC_APP_NAME="projecttt"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="info"
